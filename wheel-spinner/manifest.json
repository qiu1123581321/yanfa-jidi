{
  "manifest_version": 3,
  "name": "转盘抽奖器",
  "version": "1.0.0",
  "description": "一个精美的网页转盘抽奖插件，支持自定义奖品和概率",
  "permissions": ["activeTab", "storage"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon48.png"
    }
  },
  "icons": {
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_scripts": [],
  "web_accessible_resources": {
    "resources": ["scripts/prizes.js"]
  }
}
